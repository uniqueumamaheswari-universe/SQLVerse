-- =============================================
-- USE CASE 3: Family Dependencies (Primary → Dependents)
-- =============================================

CREATE TABLE customers (
    customer_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    booked_under INTEGER,
    relationship TEXT,
    age INTEGER,
    loyalty_points INTEGER DEFAULT 0,
    phone TEXT,
    email TEXT,
    FOREIGN KEY (booked_under) REFERENCES customers(customer_id)
);

