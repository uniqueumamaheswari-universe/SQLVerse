-- =============================================
-- Bookings Table (Links Primary Customer to Bookings)
-- =============================================

CREATE TABLE bookings (
    booking_id INTEGER PRIMARY KEY,
    primary_customer_id INTEGER NOT NULL,
    suite_type TEXT NOT NULL,
    check_in_date DATE NOT NULL,
    check_out_date DATE NOT NULL,
    total_guests INTEGER NOT NULL,
    total_amount REAL NOT NULL,
    FOREIGN KEY (primary_customer_id) REFERENCES customers(customer_id)
);

INSERT INTO bookings (booking_id, primary_customer_id, suite_type, check_in_date, check_out_date, total_guests, total_amount) VALUES
