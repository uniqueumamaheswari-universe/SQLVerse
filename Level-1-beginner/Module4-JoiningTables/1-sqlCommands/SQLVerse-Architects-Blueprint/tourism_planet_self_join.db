

-- =============================================
-- Tourism Planet Self-Join Database
-- Designed for Module 4: Self Join Practice
-- Three Use Cases: Package Tours, Guide Mentorship, Family Dependencies
-- =============================================

-- =============================================
-- USE CASE 1: Package Tours (Tour → Sub-tours)
-- =============================================

CREATE TABLE tours (
    tour_id INTEGER PRIMARY KEY,
    tour_name TEXT NOT NULL,
    parent_tour_id INTEGER,
    duration_days INTEGER NOT NULL,
    base_price REAL NOT NULL,
    description TEXT,
    FOREIGN KEY (parent_tour_id) REFERENCES tours(tour_id)
);

