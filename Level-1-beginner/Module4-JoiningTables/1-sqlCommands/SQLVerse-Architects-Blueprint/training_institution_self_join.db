-- =============================================
-- Self Join Demonstration Database – Training Institution
-- Contains: instructors with taught_by hierarchy
-- =============================================

-- Drop existing tables if present
DROP TABLE IF EXISTS instructors;

-- =============================================
-- Instructors Table with Mentor Relationship
-- =============================================
CREATE TABLE instructors (
    instructor_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    specialization TEXT,
    taught_by INTEGER,
    FOREIGN KEY (taught_by) REFERENCES instructors(instructor_id)
);

