-- =============================================
-- PEDAGOGICAL DESIGN
-- =============================================

-- NULL handling (Email)
--   Customers 6 (Frank Turner) and 7 (Grace Martin) have NULL email
--   Enables IS NULL / IS NOT NULL exercises

-- NULL handling (Phone)
--   Customers 2 (Bob Johnson) and 4 (David Kim) have NULL phone
--   Creates rich NULL combinations:
--     - Email NULL only: Frank, Grace
--     - Phone NULL only: Bob, David
--     - Both present: Alice, Charlie, Eva, Henry
--   Enables exercises combining NULL conditions

-- DISTINCT / Duplicate Cities
--   Boston appears twice (customers 6, 8)
--   Chicago appears twice (customers 2, 5, 7)
--   New York appears twice (customers 1, 3)
--   Enables DISTINCT city exercises with meaningful results

-- Comparison Operators (>, >=, <, <=, =, <>)
--   Price: Laptop (1200), Gaming Monitor (750), Smart Watch (600), Desk (250), Chair (120)
--   Quantity: 5 (Order 9) and 6 (Order 8, item 11)
--   Enables >, >=, <, <=, =, <> exercises

-- BETWEEN (Date Range)
--   Orders spread across October 1-15 AND March 1-20
--   Enables BETWEEN date range exercises

-- Category Filtering
--   Furniture category added (Desk, Chair)
--   Electronics now has 4 products (Laptop, Headphones, Gaming Monitor, Smart Watch)
--   Enables category-based filtering exercises

-- LIKE / Pattern Matching
--   Names: Alice, Bob, Charlie, David, Eva, Frank, Grace, Henry
--   Enables LIKE with '%', '_', starts with, ends with

-- Aliases
--   Column names: name, email, phone, city, product_name, etc.
--   Enables AS alias exercises

-- JOIN Exercises
--   Additional products (6,7,8,9) and orders (6-12) included
--   Enables multi-table JOIN exercises

-- Bulk Order Detection
--   quantity >= 5 returns at least two rows:
--     Order 9 (Alice, 5 Headphones)
--     Order 8, item 11 (Henry, 6 Desks)
--   Enables >= comparison with meaningful result set

-- =============================================
-- VERIFICATION QUERIES
-- =============================================

-- Customers with NULL emails
-- Expected: Frank Turner, Grace Martin
-- SELECT * FROM Customers WHERE email IS NULL;

-- Customers with NULL phone numbers
-- Expected: Bob Johnson, David Kim
-- SELECT * FROM Customers WHERE phone IS NULL;

-- Customers with missing contact details (email OR phone NULL)
-- Expected: Frank, Grace, Bob, David
-- SELECT * FROM Customers WHERE email IS NULL OR phone IS NULL;

-- Distinct cities
-- Expected: New York, Chicago, San Francisco, Boston
-- SELECT DISTINCT city FROM Customers ORDER BY city;

-- Orders with quantity >= 5
-- Expected: Order 9 (Alice, 5 Headphones), Order 8 (Henry, 6 Desks)
-- SELECT o.order_id, c.name, oi.product_id, oi.quantity
-- FROM Orders o
-- JOIN Customers c ON o.customer_id = c.customer_id
-- JOIN Order_Items oi ON o.order_id = oi.order_id
-- WHERE oi.quantity >= 5;

-- Products in Electronics category with price > 500
-- Expected: Laptop, Gaming Monitor, Smart Watch
-- SELECT * FROM Products WHERE category = 'Electronics' AND price > 500;

-- Orders on or after March 1, 2025
-- Expected: 3 orders (10, 11, 12)
-- SELECT * FROM Orders WHERE order_date >= '2025-03-01';

-- Products in Furniture category
-- Expected: Desk, Chair
-- SELECT * FROM Products WHERE category = 'Furniture';

-- Customers from Boston with email
-- Expected: Henry Williams
-- SELECT * FROM Customers WHERE city = 'Boston' AND email IS NOT NULL;

