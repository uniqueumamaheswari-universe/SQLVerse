-- Here is the complete SQL dataset for **FinVERSE — Digital Banking Ecosystem**.

-- It includes:
- **10 tables** with realistic sample data
- **Production‑style edge cases** (NULLs, fraud flags, overdue loans, open tickets)
- **Multiple rows per customer/account/loan** for JOIN and aggregation exercises
- **Self‑join** data for employees/managers

---

-- =============================================
-- FinVERSE — Digital Banking Ecosystem
-- For ACCELERATE Phase | Module 2 APPLY
-- 
-- Location:
--   Module5-GenAI-Walkthrough/02-Exercises/MODULE2/Module2-Schemas/
--   finverse.db
-- =============================================

-- =============================================
-- DROP TABLES (if they already exist)
-- =============================================
DROP TABLE IF EXISTS loan_payments;
DROP TABLE IF EXISTS loans;
DROP TABLE IF EXISTS support_tickets;
DROP TABLE IF EXISTS cards;
DROP TABLE IF EXISTS transactions;
DROP TABLE IF EXISTS accounts;
DROP TABLE IF EXISTS customers;
DROP TABLE IF EXISTS merchants;
DROP TABLE IF EXISTS employees;
DROP TABLE IF EXISTS branches;

-- =============================================
-- CREATE TABLES
-- =============================================

-- ---------- Branches ----------
CREATE TABLE branches (
    branch_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    city TEXT NOT NULL,
    state TEXT NOT NULL,
    status TEXT NOT NULL  -- 'Active', 'Closed', 'Temporarily Closed'
);

-- ---------- Employees ----------
CREATE TABLE employees (
    employee_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    role TEXT NOT NULL,  -- 'Support Agent', 'Credit Officer', 'Fraud Analyst', 'Relationship Manager', 'Branch Manager'
    manager_id INTEGER,
    branch_id INTEGER,
    FOREIGN KEY (manager_id) REFERENCES employees(employee_id),
    FOREIGN KEY (branch_id) REFERENCES branches(branch_id)
);

-- ---------- Customers ----------
CREATE TABLE customers (
    customer_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT,
    phone TEXT,
    kyc_status TEXT NOT NULL,  -- 'Pending', 'Verified', 'Rejected', 'Incomplete'
    risk_score TEXT NOT NULL,  -- 'Low', 'Medium', 'High'
    onboarding_date TEXT NOT NULL,
    status TEXT NOT NULL  -- 'Active', 'Inactive', 'Suspended', 'Closed'
);

-- ---------- Accounts ----------
CREATE TABLE accounts (
    account_id INTEGER PRIMARY KEY,
    customer_id INTEGER NOT NULL,
    account_type TEXT NOT NULL,  -- 'Savings', 'Current', 'Salary', 'Joint'
    balance REAL NOT NULL,
    status TEXT NOT NULL,  -- 'Active', 'Dormant', 'Closed', 'Frozen'
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);

-- ---------- Merchants ----------
CREATE TABLE merchants (
    merchant_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    category TEXT NOT NULL,  -- 'Retail', 'E-Commerce', 'Food', 'Travel', 'Utilities'
    settlement_type TEXT NOT NULL,  -- 'Daily', 'Weekly', 'Monthly'
    status TEXT NOT NULL  -- 'Active', 'Suspended', 'Inactive'
);

-- ---------- Transactions ----------
CREATE TABLE transactions (
    transaction_id INTEGER PRIMARY KEY,
    account_id INTEGER NOT NULL,
    merchant_id INTEGER,
    amount REAL NOT NULL,
    transaction_type TEXT NOT NULL,  -- 'Debit', 'Credit', 'Transfer', 'Payment'
    transaction_date TEXT NOT NULL,
    status TEXT NOT NULL,  -- 'Pending', 'Completed', 'Failed', 'Reversed'
    is_fraud INTEGER NOT NULL,  -- 0 = FALSE, 1 = TRUE
    FOREIGN KEY (account_id) REFERENCES accounts(account_id),
    FOREIGN KEY (merchant_id) REFERENCES merchants(merchant_id)
);

-- ---------- Cards ----------
CREATE TABLE cards (
    card_id INTEGER PRIMARY KEY,
    account_id INTEGER NOT NULL,
    card_type TEXT NOT NULL,  -- 'Debit', 'Credit', 'Prepaid'
    card_number TEXT NOT NULL,  -- Masked (e.g., '****1234')
    expiry_date TEXT NOT NULL,
    status TEXT NOT NULL,  -- 'Active', 'Blocked', 'Expired', 'Lost'
    FOREIGN KEY (account_id) REFERENCES accounts(account_id)
);

-- ---------- Loans ----------
CREATE TABLE loans (
    loan_id INTEGER PRIMARY KEY,
    customer_id INTEGER NOT NULL,
    principal REAL NOT NULL,
    interest_rate REAL NOT NULL,
    tenure_months INTEGER NOT NULL,
    outstanding_balance REAL NOT NULL,
    status TEXT NOT NULL,  -- 'Active', 'Completed', 'Defaulted', 'Pending'
    approval_date TEXT NOT NULL,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);

-- ---------- Loan Payments ----------
CREATE TABLE loan_payments (
    payment_id INTEGER PRIMARY KEY,
    loan_id INTEGER NOT NULL,
    amount REAL NOT NULL,
    payment_date TEXT NOT NULL,
    payment_method TEXT NOT NULL,  -- 'Bank Transfer', 'Card', 'Cash', 'UPI'
    status TEXT NOT NULL,  -- 'Pending', 'Completed', 'Failed'
    FOREIGN KEY (loan_id) REFERENCES loans(loan_id)
);

-- ---------- Support Tickets ----------
CREATE TABLE support_tickets (
    ticket_id INTEGER PRIMARY KEY,
    customer_id INTEGER NOT NULL,
    employee_id INTEGER,
    ticket_type TEXT NOT NULL,  -- 'Account Issue', 'Card Issue', 'Transaction Dispute', 'Loan Query', 'Fraud Report'
    status TEXT NOT NULL,  -- 'Open', 'In Progress', 'Resolved', 'Closed'
    created_date TEXT NOT NULL,
    resolved_date TEXT,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY (employee_id) REFERENCES employees(employee_id)
);

