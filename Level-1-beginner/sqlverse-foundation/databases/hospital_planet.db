
-- =============================================
-- Hospital Planet Database (ACCELERATE Module 2)
-- Used for Production Echo exercises
--
-- This dataset is designed to support:
--   - Logical operators (AND, OR, NOT, IN)
--   - Range filtering (BETWEEN, >, <)
--   - Pattern matching (LIKE, wildcards)
--   - NULL handling (IS NULL, IS NOT NULL)
--   - Aggregation (GROUP BY, SUM, COUNT, HAVING) in Module 3
--   - JOINs (INNER JOIN, LEFT JOIN, multi-table) in Module 4
--
-- Location:
--   Module5-GenAI-Walkthrough/02-Exercises/MODULE2/Module2-Schemas/
--   hospital_planet.db
-- =============================================

-- =============================================
-- DROP TABLES (if they already exist)
-- =============================================
DROP TABLE IF EXISTS bills;
DROP TABLE IF EXISTS appointments;
DROP TABLE IF EXISTS treatments;
DROP TABLE IF EXISTS patients;

-- =============================================
-- CREATE TABLES
-- =============================================

-- 1. Patients Table
CREATE TABLE patients (
    patient_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    email TEXT NOT NULL,
    phone TEXT,
    status TEXT DEFAULT 'Active'
);

-- 2. Treatments Table
CREATE TABLE treatments (
    treatment_id INTEGER PRIMARY KEY,
    treatment_name TEXT NOT NULL,
    cost REAL NOT NULL,
    category TEXT
);

-- 3. Appointments Table
CREATE TABLE appointments (
    appointment_id INTEGER PRIMARY KEY,
    patient_id INTEGER NOT NULL,
    appointment_date TEXT NOT NULL,
    treatment_id INTEGER,
    FOREIGN KEY (patient_id) REFERENCES patients(patient_id),
    FOREIGN KEY (treatment_id) REFERENCES treatments(treatment_id)
);

-- 4. Bills Table
CREATE TABLE bills (
    bill_id INTEGER PRIMARY KEY,
    patient_id INTEGER NOT NULL,
    amount REAL NOT NULL,
    bill_date TEXT NOT NULL,
    FOREIGN KEY (patient_id) REFERENCES patients(patient_id)
);

