
-- =============================================
-- Real Estate Planet Database (ACCELERATE Module 2)
-- Used for APPLY Exercises 3, 4, 5 and future JOIN/aggregation modules
--
-- This dataset is designed to support:
--   - Logical operators (AND, OR, NOT, IN)
--   - Range filtering (BETWEEN, >, <)
--   - Pattern matching (LIKE, wildcards)
--   - NULL handling (IS NULL, IS NOT NULL)
--   - Aggregation (GROUP BY, SUM, COUNT, HAVING) in Module 3
--   - JOINs (INNER JOIN, LEFT JOIN, multi-table) in Module 4
--
-- Location:
--   Module5-GenAI-Walkthrough/02-Exercises/MODULE2/Module2-Schemas/
--   real_estate_planet.db
-- =============================================

-- =============================================
-- DROP TABLES (if they already exist)
-- =============================================
DROP TABLE IF EXISTS payments;
DROP TABLE IF EXISTS contracts;
DROP TABLE IF EXISTS offers;
DROP TABLE IF EXISTS viewings;
DROP TABLE IF EXISTS properties;
DROP TABLE IF EXISTS clients;
DROP TABLE IF EXISTS agents;

-- =============================================
-- CREATE TABLES
-- =============================================

-- 1. Agents
CREATE TABLE agents (
    agent_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT,
    phone TEXT,
    brokerage TEXT NOT NULL
);

-- 2. Clients
CREATE TABLE clients (
    client_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT,
    phone TEXT,
    client_type TEXT NOT NULL  -- 'Buyer', 'Seller', 'Both'
);

-- 3. Properties
CREATE TABLE properties (
    property_id INTEGER PRIMARY KEY,
    agent_id INTEGER NOT NULL,
    address TEXT NOT NULL,
    city TEXT NOT NULL,
    state TEXT NOT NULL,
    zip TEXT,
    property_type TEXT NOT NULL,
    list_price REAL NOT NULL,
    status TEXT NOT NULL,  -- 'Active', 'Pending', 'Sold', 'Withdrawn'
    FOREIGN KEY (agent_id) REFERENCES agents(agent_id)
);

-- 4. Viewings
CREATE TABLE viewings (
    viewing_id INTEGER PRIMARY KEY,
    property_id INTEGER NOT NULL,
    client_id INTEGER NOT NULL,
    viewing_date TEXT NOT NULL,
    feedback TEXT,
    FOREIGN KEY (property_id) REFERENCES properties(property_id),
    FOREIGN KEY (client_id) REFERENCES clients(client_id)
);

-- 5. Offers
CREATE TABLE offers (
    offer_id INTEGER PRIMARY KEY,
    property_id INTEGER NOT NULL,
    client_id INTEGER NOT NULL,
    agent_id INTEGER NOT NULL,
    offer_amount REAL NOT NULL,
    offer_date TEXT NOT NULL,
    status TEXT NOT NULL,  -- 'Pending', 'Accepted', 'Rejected', 'Withdrawn'
    FOREIGN KEY (property_id) REFERENCES properties(property_id),
    FOREIGN KEY (client_id) REFERENCES clients(client_id),
    FOREIGN KEY (agent_id) REFERENCES agents(agent_id)
);

-- 6. Contracts
CREATE TABLE contracts (
    contract_id INTEGER PRIMARY KEY,
    offer_id INTEGER NOT NULL UNIQUE,  -- one accepted offer becomes one contract
    property_id INTEGER NOT NULL,
    client_id INTEGER NOT NULL,
    agent_id INTEGER NOT NULL,
    sale_price REAL NOT NULL,
    closing_date TEXT NOT NULL,
    FOREIGN KEY (offer_id) REFERENCES offers(offer_id),
    FOREIGN KEY (property_id) REFERENCES properties(property_id),
    FOREIGN KEY (client_id) REFERENCES clients(client_id),
    FOREIGN KEY (agent_id) REFERENCES agents(agent_id)
);

-- 7. Payments
CREATE TABLE payments (
    payment_id INTEGER PRIMARY KEY,
    contract_id INTEGER NOT NULL,
    payment_date TEXT NOT NULL,
    amount REAL NOT NULL,
    payment_method TEXT NOT NULL,  -- 'Wire', 'Cash', 'Check', 'ACH'
    FOREIGN KEY (contract_id) REFERENCES contracts(contract_id)
);

