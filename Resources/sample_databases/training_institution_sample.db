-- =============================================
-- Training Institution Sample Database
-- Optimized for Level 1 & Level 2 Mastery
-- =============================================

-- =============================================
--CREATING TABLES
-- =============================================


-- 1. Create Instructors Table (The Source of Truth for Faculty)
CREATE TABLE instructors (
    instructor_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    specialization TEXT
);

-- 2. Create Students Table
CREATE TABLE students (
    student_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    phone TEXT,
    enrollment_date DATE NOT NULL,
    total_fees DECIMAL(10,2) DEFAULT 0,
    fees_paid DECIMAL(10,2) DEFAULT 0
);

-- 3. Create Courses Table (Linked to Instructors)
CREATE TABLE courses (
    course_id INTEGER PRIMARY KEY,
    course_code TEXT NOT NULL UNIQUE,
    course_name TEXT NOT NULL,
    course_track TEXT NOT NULL,
    duration_weeks INTEGER NOT NULL,
    instructor_id INTEGER NOT NULL, -- The Foreign Key
    course_fee DECIMAL(8,2) NOT NULL,
    max_seats INTEGER NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (instructor_id) REFERENCES instructors(instructor_id)
);

-- 4. Create Enrollments Table
CREATE TABLE enrollments (
    enrollment_id INTEGER PRIMARY KEY,
    student_id INTEGER NOT NULL,
    course_id INTEGER NOT NULL,
    enrollment_date DATE NOT NULL,
    completion_status TEXT DEFAULT 'Ongoing',
    test1_score DECIMAL(5,2),
    test2_score DECIMAL(5,2),
    final_exam_score DECIMAL(5,2),
    certificate_issued BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (student_id) REFERENCES students(student_id),
    FOREIGN KEY (course_id) REFERENCES courses(course_id)
);

-- 5. Create Payments Table
CREATE TABLE payments (
    payment_id INTEGER PRIMARY KEY,
    student_id INTEGER NOT NULL,
    amount DECIMAL(8,2) NOT NULL,
    payment_date DATE NOT NULL,
    payment_method TEXT NOT NULL,
    description TEXT,
    FOREIGN KEY (student_id) REFERENCES students(student_id)
);

